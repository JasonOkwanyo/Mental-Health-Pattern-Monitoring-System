from datetime import datetime
import re

class MoodEntry:
    def __init__(self, mood, trigger, stress_level):
        self.timestamp = datetime.now()
        self.mood = mood
        self.trigger = trigger
        self.stress_level = stress_level

    def __str__(self):
        time_str = self.timestamp.strftime("%Y-%m-%d %H:%M:%S")
        return f" Time: {time_str} | Mood: {self.mood} | Trigger: {self.trigger} | Stress Level: {self.stress_level}"

class TreeNode:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None

class AnalysisData:
    def __init__(self):
        self.high_stress_days = 0
        self.mood_frequency = {}

class MentalHealthMonitoringSystem:
    def __init__(self):
        self.root = None

    def insert(self, node, data):
        if node is None:
            return TreeNode(data)
        if data.timestamp < node.data.timestamp:
            node.left = self.insert(node.left, data)
        else:
            node.right = self.insert(node.right, data)
        return node

    def display_history_chronological(self, node):
        if node is not None:
            self.display_history_chronological(node.left)
            print(node.data)
            self.display_history_chronological(node.right)

    def compute_patterns(self, node, data):
        if node is not None:
            self.compute_patterns(node.left, data)
            if node.data.stress_level >= 7:
                data.high_stress_days += 1
            data.mood_frequency[node.data.mood] = data.mood_frequency.get(node.data.mood, 0) + 1
            self.compute_patterns(node.right, data)

    def show_welcome(self):
        print("\nMENTAL HEALTH TREE STORAGE")
        print("\nDatabase Login System\n")
        print(" System initialized successfully!")

    def show_help(self):
        print("\nadd     -> Log a mood entry anytime")
        print("history -> View sorted mood history")
        print("analyze -> Analyze emotional patterns")
        print("help    -> Display system commands")
        print("exit    -> Exit program")

    def add_mood_entry(self):
        print("\nREAL-TIME LOGIN")

        while True:
            try:
                mood = input("Enter Mood: ").strip()
                if not mood or not re.match(r"^[a-zA-Z\s]+$", mood):
                    raise ValueError("Mood must only contain letters (no numbers or special characters).")
                break
            except ValueError as e:
                print(f"Invalid Input: {e}")

        while True:
            try:
                trigger = input("Enter Trigger: ").strip()
                if not trigger or not re.match(r"^[a-zA-Z\s]+$", trigger):
                    raise ValueError("Trigger must only contain letters (no numbers or special characters).")
                break
            except ValueError as e:
                print(f"Invalid Input: {e}")

        while True:
            try:
                stress_level_input = input("Enter Stress Level (1-10): ")
                stress_level = int(stress_level_input)
                if 1 <= stress_level <= 10:
                    break
                print("Stress level must be between 1 and 10.")
            except ValueError:
                print("Invalid number. Please enter a digit (1-10).")
            except Exception:
                print("An unexpected error occurred.")

        entry = MoodEntry(mood, trigger, stress_level)
        self.root = self.insert(self.root, entry)
        print("\nLog recorded dynamically into the tree structure!")

    def view_history(self):
        print("\nCHRONOLOGICAL TREE TRAVERSAL")
        if self.root is None:
            print("Database is currently empty.")
            return
        self.display_history_chronological(self.root)

    def analyze_patterns(self):
        print("\nPATTERN RECOGNITION")
        if self.root is None:
            print("Insufficient data for analysis.")
            return

        data = AnalysisData()
        self.compute_patterns(self.root, data)

        print(f"Total High Stress Incidents (>=7): {data.high_stress_days}")
        print("\nLogged Mood Frequencies:")
        for mood, count in data.mood_frequency.items():
            print(f" - {mood}: {count} time(s)")

        if data.high_stress_days >= 3:
            print("\nBurnout patterns detected through records.")
        else:
            print("\n Analysis indicates stable mental health.")

    def run(self):
        self.show_welcome()
        while True:
            command = input("\nMentalHealthTree Database> ").strip().lower()
            if command == "add":
                self.add_mood_entry()
            elif command == "history":
                self.view_history()
            elif command == "analyze":
                self.analyze_patterns()
            elif command == "help":
                self.show_help()
            elif command == "exit":
                print("\nClosing System...")
                print("Goodbye!")
                break
            else:
                print("\nUnknown command. Type 'help' to view valid options.")

if __name__ == "__main__":
    system = MentalHealthMonitoringSystem()
    system.run()
