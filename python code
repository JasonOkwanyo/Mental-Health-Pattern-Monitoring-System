import collections

# COLORS FOR TERMINAL OUTPUT
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RED = "\033[31m"
RESET = "\033[0m"

class MoodEntry:
    """Class to represent a single daily mood entry[cite: 29]."""
    def __init__(self, date, mood, trigger, stress_level):
        self.date = date
        self.mood = mood
        self.trigger = trigger
        self.stress_level = stress_level

    def __str__(self):
        return f"Date: {self.date} | Mood: {self.mood} | Trigger: {self.trigger} | Stress Level: {self.stress_level}"

class TreeNode:
    """Hierarchical structure to categorize mental states and triggers[cite: 31]."""
    def __init__(self, category):
        self.category = category
        self.children = []

    def add_child(self, child_node):
        self.children.append(child_node)

    def display(self, indent=""):
        print(f"{indent}{self.category}")
        for child in self.children:
            child.display(indent + "   ")

class MentalHealthMonitoringSystem:
    def __init__(self):
        # QUEUE: Stores entries in chronological order [cite: 29]
        self.mood_queue = collections.deque()
        
        # STACK: Maintains recent history for undo functionality [cite: 30]
        self.recent_entries = []
        
        # GRAPH: Adjacency list modeling relationships between emotions and triggers [cite: 32]
        self.emotion_graph = {}
        
        # TREE: Hierarchical categorization of mental health states [cite: 31]
        self.root = self._initialize_tree()

    def _initialize_tree(self):
        root = TreeNode("Mental Health")
        
        stress = TreeNode("Stress")
        stress.add_child(TreeNode("Academic Pressure"))
        stress.add_child(TreeNode("Workload"))
        stress.add_child(TreeNode("Financial Problems"))
        
        anxiety = TreeNode("Anxiety")
        anxiety.add_child(TreeNode("Social Anxiety"))
        anxiety.add_child(TreeNode("Fear of Failure"))
        
        burnout = TreeNode("Burnout")
        burnout.add_child(TreeNode("Overworking"))
        burnout.add_child(TreeNode("Lack of Sleep"))
        
        emotional = TreeNode("Emotional State")
        emotional.add_child(TreeNode("Happiness"))
        emotional.add_child(TreeNode("Sadness"))
        
        root.children.extend([stress, anxiety, burnout, emotional])
        return root

    def add_mood_entry(self):
        print("\n========== ADD MOOD ENTRY ==========")
        date = input("Enter Date (YYYY-MM-DD): ")
        mood = input("Enter Mood: ")
        trigger = input("Enter Trigger: ")
        
        # Valid and Invalid Input Testing: Handling the stress level range [cite: 12]
        while True:
            try:
                stress_level = int(input("Enter Stress Level (1-10): "))
                if 1 <= stress_level <= 10:
                    break
                print(f"{RED}Invalid input. Stress level must be 1-10.{RESET}")
            except ValueError:
                print(f"{RED}Invalid input. Please enter a whole number.{RESET}")

        entry = MoodEntry(date, mood, trigger, stress_level)
        
        self.mood_queue.append(entry) # Add to Queue
        self.recent_entries.append(entry) # Push to Stack
        
        # Update Graph Adjacency List
        if mood not in self.emotion_graph:
            self.emotion_graph[mood] = []
        self.emotion_graph[mood].append(trigger)
        
        print(f"{GREEN}\nMood entry added successfully.вң”{RESET}")

    def view_history(self):
        print("\n========== MOOD HISTORY ==========")
        if not self.mood_queue:
            print("No entries found.")
            return
        
        for entry in self.mood_queue:
            print("-" * 30)
            print(f"рҹ“… Date   : {entry.date}")
            print(f"рҹҳҠ Mood   : {entry.mood}")
            print(f"вҡЎ Trigger: {entry.trigger}")
            print(f"рҹ”Ҙ Stress : {entry.stress_level}")
        print("-" * 30)

    def undo_entry(self):
        """Removes the most recent entry using Stack logic[cite: 30]."""
        if not self.recent_entries:
            print("\nNothing to undo.")
            return
        
        removed = self.recent_entries.pop() # Stack pop
        self.mood_queue.remove(removed) # Queue removal
        print(f"\n{YELLOW}Removed recent entry:{RESET}\n{removed}")

    def analyze_patterns(self):
        """Analyzes data to detect potential risk situations like burnout[cite: 33]."""
        print("\nв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—")
        print("в•‘   рҹ“Ҡ PATTERN ANALYSIS      в•‘")
        print("в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ")
        
        if not self.mood_queue:
            print("No data to analyze.")
            return

        high_stress_days = 0
        mood_freq = {}

        for entry in self.mood_queue:
            if entry.stress_level >= 7:
                high_stress_days += 1
            mood_freq[entry.mood] = mood_freq.get(entry.mood, 0) + 1

        print(f"High Stress Days Detected: {high_stress_days}")
        print("\nMood Frequency:")
        for mood, count in mood_freq.items():
            print(f" - {mood}: {count}")

        # Burnout logic: 3 or more high stress days [cite: 33]
        if high_stress_days >= 3:
            print(f"\n{RED}вҡ пёҸ  ALERT: Possible prolonged stress or burnout detected!{RESET}")
        else:
            print(f"\n{GREEN}Stress levels appear manageable.{RESET}")

    def display_graph(self):
        print("\nв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—")
        print("в•‘   рҹ”— EMOTIONвҖ“TRIGGER NETWORK       в•‘")
        print("в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ")
        if not self.emotion_graph:
            print("Graph is empty.")
            return
        
        for emotion, triggers in self.emotion_graph.items():
            print(f"\nрҹ”№ {emotion}")
            for trigger in triggers:
                print(f"   в””в”Җв”Җ {trigger}")

def main():
    system = MentalHealthMonitoringSystem()
    
    print("\nв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—")
    print("в•‘   рҹ§  MENTAL HEALTH MONITORING SYSTEM      в•‘")
    print("в•‘   Emotional Pattern Tracking Dashboard    в•‘")
    print("в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ")

    commands = {
        "add": system.add_mood_entry,
        "history": system.view_history,
        "undo": system.undo_entry,
        "tree": lambda: system.root.display(),
        "graph": system.display_graph,
        "analyze": system.analyze_patterns,
        "help": lambda: print("\nCommands: add, history, undo, tree, graph, analyze, help, exit")
    }

    while True:
        choice = input("\nMentalHealthSystem> ").strip().lower()
        if choice == "exit":
            print("Exiting...")
            break
        elif choice in commands:
            commands[choice]()
        else:
            print("Unknown command. Type 'help' for options.")

if __name__ == "__main__":
    main()
