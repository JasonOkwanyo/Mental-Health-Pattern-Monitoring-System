import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.*;

public class MentalHealthMonitoringSystem {
    static class MoodEntry {
        LocalDateTime timestamp; 
        String mood;
        String trigger;
        int stressLevel;

        public MoodEntry(String mood, String trigger, int stressLevel) {
            this.timestamp = LocalDateTime.now();
            this.mood = mood;
            this.trigger = trigger;
            this.stressLevel = stressLevel;
        }

        @Override
        public String toString() {
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("YYYY-MM-DD HH:mm:ss");
            return " Time: " + timestamp.format(formatter) +
                   " | Mood: " + mood +
                   " | Trigger: " + trigger +
                   " | Stress Level: " + stressLevel;
        }
    }

    static class TreeNode {
        MoodEntry data;
        TreeNode left;
        TreeNode right;

        public TreeNode(MoodEntry data) {
            this.data = data;
            this.left = null;
            this.right = null;
        }
    }

    private static TreeNode root = null;
    private static final Scanner scanner = new Scanner(System.in);

    public static TreeNode insert(TreeNode node, MoodEntry data) {
        if (node == null) {
            return new TreeNode(data);
        }
        if (data.timestamp.isBefore(node.data.timestamp)) {
            node.left = insert(node.left, data);
        } else {
            node.right = insert(node.right, data);
        }
        return node;
    }

    public static void displayHistoryChronological(TreeNode node) {
        if (node != null) {
            displayHistoryChronological(node.left);
            System.out.println(node.data);
            displayHistoryChronological(node.right);
        }
    }

    static class AnalysisData {
        int highStressDays = 0;
        Map<String, Integer> moodFrequency = new HashMap<>();
    }

    public static void computePatterns(TreeNode node, AnalysisData data) {
        if (node != null) {
            computePatterns(node.left, data);

            if (node.data.stressLevel >= 7) {
                data.highStressDays++;
            }
            data.moodFrequency.put(node.data.mood, data.moodFrequency.getOrDefault(node.data.mood, 0) + 1);

            computePatterns(node.right, data);
        }
    }

    public static void main(String[] args) {
        showWelcome();

        while (true) {
            System.out.print("\nMentalHealthTree Database> ");
            String command = scanner.nextLine().trim().toLowerCase();

            switch (command) {
                case "add":
                    addMoodEntry();
                    break;

                case "history":
                    viewHistory();
                    break;

                case "analyze":
                    analyzePatterns();
                    break;

                case "help":
                    showHelp();
                    break;

                case "exit":
                    System.out.println("\nClosing System...");
                    System.out.println("Goodbye!");
                    return;

                default:
                    System.out.println("\nUnknown command. Type 'help' to view valid options.");
            }
        }
    }

    public static void showWelcome() {
        System.out.println("\nMENTAL HEALTH TREE STORAGE");
        System.out.println("\nDatabase Login System\n");
        System.out.println(" System initialized successfully!");
    }

    public static void showHelp() {
        System.out.println("\nadd     -> Log a mood entry anytime");
        System.out.println("history -> View sorted mood history");
        System.out.println("analyze -> Analyze emotional patterns");
        System.out.println("help    -> Display system commands");
        System.out.println("exit    -> Exit program");
    }

    public static void addMoodEntry() {
        System.out.println("\nREAL-TIME LOGIN");

	String mood;
        while (true) {
        try {
            System.out.print("Enter Mood: ");
            mood = scanner.nextLine().trim();

            if (mood.isEmpty() || !mood.matches("[a-zA-Z\\s]+")) {
                throw new IllegalArgumentException("Mood must only contain letters (no numbers or special characters).");
            }
            break;
        } catch (IllegalArgumentException e) {
            System.out.println("Invalid Input: " + e.getMessage());
        }
    	}

	String trigger;
        while (true) {
        try {
            System.out.print("Enter Trigger: ");
            trigger = scanner.nextLine().trim();

            if (trigger.isEmpty() || !trigger.matches("[a-zA-Z\\s]+")) {
                throw new IllegalArgumentException("Trigger must only contain letters (no numbers or special characters).");
            }
            break;
        } catch (IllegalArgumentException e) {
            System.out.println("Invalid Input: " + e.getMessage());
        }
    	}
	
	int stressLevel;
        while (true) {
        try {
            System.out.print("Enter Stress Level (1-10): ");
            stressLevel = Integer.parseInt(scanner.nextLine());
            if (stressLevel >= 1 && stressLevel <= 10) break;
            System.out.println("Stress level must be between 1 and 10.");
        } catch (NumberFormatException e) {
            System.out.println("Invalid number. Please enter a digit (1-10).");
        } catch (Exception e) {
            System.out.println("An unexpected error occurred.");
        }
    	}

        MoodEntry entry = new MoodEntry(mood, trigger, stressLevel);
        root = insert(root, entry); 
        System.out.println("\nLog recorded dynamically into the tree structure!");
    }

    public static void viewHistory() {
        System.out.println("\nCHRONOLOGICAL TREE TRAVERSAL");
        if (root == null) {
            System.out.println("Database is currently empty.");
            return;
        }
        displayHistoryChronological(root);
    }

    public static void analyzePatterns() {
        System.out.println("\nPATTERN RECOGNITION");
        if (root == null) {
            System.out.println("Insufficient data for analysis.");
            return;
        }

        AnalysisData data = new AnalysisData();
        computePatterns(root, data);

        System.out.println("Total High Stress Incidents (>=7): " + data.highStressDays);
        System.out.println("\nLogged Mood Frequencies:");
        for (String mood : data.moodFrequency.keySet()) {
            System.out.println(" - " + mood + ": " + data.moodFrequency.get(mood) + " time(s)");
        }

        if (data.highStressDays >= 3) {
            System.out.println("\nBurnout patterns detected through records.");
        } else {
            System.out.println("\n Analysis indicates stable mental health.");
        }
    }
}
